# LLM provider (anthropic | openai | deepseek | moonshot) — required before running the batch
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001

# API keys — set the one that matches LLM_PROVIDER
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Service desk provider (freshdesk) — required before running the batch
SERVICEDESK_PROVIDER=freshdesk

# Freshdesk credentials
FRESHDESK_DOMAIN=yourcompany.freshdesk.com
FRESHDESK_API_KEY=your_freshdesk_api_key_here

# Oracle (for db-mcp)
ORACLE_DSN=your_oracle_dsn_here
ORACLE_USER=readonly_user
ORACLE_PASSWORD=readonly_password
ORACLE_SCHEMAS=SCHEMA1,SCHEMA2

# Source code (for code-mcp)
SOURCE_ROOT=C:/path/to/java/project

# docs-mcp
DOCS_DIR=docs/corpus
CHROMA_DIR=data/chromadb

# App
DATABASE_URL=sqlite:///./data/scout.db
